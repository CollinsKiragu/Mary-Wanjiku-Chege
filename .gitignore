# ==========================================
# ENVIRONMENT FILES (NEVER commit secrets)
# ==========================================
.env
.env.local
.env.production
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# ==========================================
# RAILS / RUBY
# ==========================================
backend/node_modules/
backend/vendor/bundle/
backend/tmp/
backend/log/
backend/storage/*.sqlite3
backend/storage/*.sqlite3-*
backend/public/assets/
backend/public/packs/
backend/.bundle/
backend/bootsnap-compile-cache/

# ==========================================
# REACT / NODE
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/

# ==========================================
# IDE & OS FILES
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# LOGS & TEMP FILES
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp

# ==========================================
# DATABASE (PostgreSQL credentials if any)
# ==========================================
backend/config/database.yml.bak
backend/config/master.key
backend/config/credentials.yml.enc
